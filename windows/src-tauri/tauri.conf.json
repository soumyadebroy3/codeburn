{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeBurn Tray",
  "version": "2.3.0",
  "identifier": "com.soumyadebroy3.codeburn-tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "popover",
        "title": "CodeBurn",
        "width": 380,
        "height": 560,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "windowEffects": {
          "effects": ["mica", "acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "soumyadebroy3",
    "copyright": "MIT — Forked from getagentseal/codeburn",
    "category": "DeveloperTool",
    "shortDescription": "AI coding cost tracker (Windows tray)",
    "longDescription": "See where your AI coding tokens go — by task, tool, model, and project. Windows system-tray companion to the codeburn CLI.",
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
